#!/usr/bin/env bash
set -euo pipefail

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🔍 Pre-commit Checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 1. Formatting check
echo ""
echo "📝 [1/5] Formatting check..."
# WHY: Get list of staged Dart files to format only what's being committed
staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.dart$' || true)

if [ -z "$staged_files" ]; then
  echo "   No Dart files staged, skipping formatting check."
else
  # WHY: Format only staged files to avoid affecting unstaged changes
  echo "$staged_files" | xargs -I {} dart format {} > /dev/null 2>&1 || true

  # WHY: Check if formatted working directory files differ from staged versions
  # We check git diff (not --cached) for each staged file
  # This tells us if formatting changed the files relative to what's staged
  formatted_files=""
  while IFS= read -r file; do
    if [ -n "$file" ] && [ -f "$file" ]; then
      # WHY: Check if working directory file differs from staged version
      # git diff (without --cached) compares working directory to index
      if ! git diff --quiet "$file" 2>/dev/null; then
        formatted_files="$formatted_files $file"
      fi
    fi
  done <<< "$staged_files"

  if [ -n "$formatted_files" ]; then
    echo "   Auto-staging formatted files..."
    # WHY: Automatically stage the formatted files so user doesn't need to commit twice
    echo "$formatted_files" | xargs git add 2>/dev/null || true
    echo "   ✓ Formatted files have been staged automatically"
  fi
fi

# 2. Static analysis
echo ""
echo "🔍 [2/5] Static analysis..."
flutter analyze || {
  echo "❌ Static analysis failed!"
  exit 1
}

# 3. Code generation
echo ""
echo "⚙️  [3/5] Code generation..."
flutter pub run build_runner build --delete-conflicting-outputs || {
  echo "❌ Code generation failed!"
  exit 1
}

# 4. Run tests (excluding golden tests - run separately)
echo ""
echo "🧪 [4/5] Running unit and widget tests..."
flutter test --coverage --exclude-tags=golden --concurrency=1 || {
  echo "❌ Tests failed!"
  exit 1
}

# 5. Golden tests
echo ""
echo "🖼️  [5/5] Checking golden tests..."
if ! flutter test test/golden/ --concurrency=1; then
  echo ""
  echo "❌ Golden tests failed!"
  echo ""
  echo "If UI changes are intentional, run:"
  echo "  flutter test test/golden/ --update-goldens"
  echo ""
  echo "Then review the changes and commit the updated golden files."
  exit 1
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ All pre-commit checks passed!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"


